# ══════════════════════════════════════════════════════════════════════════════
# CANSLIM SCANNER - CONFIGURATION FILE
# ══════════════════════════════════════════════════════════════════════════════
# Copy file này thành .env và điền các API keys của bạn
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# VNSTOCK API (Premium)
# ─────────────────────────────────────────────────────────────────────────────
# Đăng ký tại: https://vnstocks.com
VNSTOCK_API_KEY=your_vnstock_api_key_here

# Nguồn dữ liệu: VCI hoặc TCBS
VNSTOCK_SOURCE=VCI

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDER
# ─────────────────────────────────────────────────────────────────────────────
# Chọn 1 trong các provider: deepseek | gemini | claude | openai | groq
AI_PROVIDER=deepseek

# ─────────────────────────────────────────────────────────────────────────────
# DEEPSEEK (Khuyến nghị - Rẻ nhất, chất lượng tốt)
# ─────────────────────────────────────────────────────────────────────────────
# Đăng ký: https://platform.deepseek.com/
# Giá: ~$0.14/1M input tokens (RẺ NHẤT)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE GEMINI (Free tier rộng rãi)
# ─────────────────────────────────────────────────────────────────────────────
# Đăng ký: https://makersuite.google.com/app/apikey
# Giá: Free 60 requests/phút
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC CLAUDE (Chất lượng cao nhất)
# ─────────────────────────────────────────────────────────────────────────────
# Đăng ký: https://console.anthropic.com/
# Giá: $3/1M input, $15/1M output (sonnet)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# OPENAI (Phổ biến)
# ─────────────────────────────────────────────────────────────────────────────
# Đăng ký: https://platform.openai.com/
# Giá: $2.5/1M input (gpt-4o-mini)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# GROQ (Nhanh nhất)
# ─────────────────────────────────────────────────────────────────────────────
# Đăng ký: https://console.groq.com/
# Giá: Free tier generous
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# OUTPUT SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
SAVE_REPORTS=true
